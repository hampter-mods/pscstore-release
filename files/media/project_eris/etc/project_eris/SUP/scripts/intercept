source "/var/volatile/project_eris.cfg"

### LOAD FUNCTION LIBRARIES ###################################################
source "/media/project_eris/etc/project_eris/FUNC/0030_retroarch.funcs"

### INTERCEPT VARIABLES #######################################################
INTERCEPT_PCSX_PATH="/usr/sony/bin/pcsx"
INTERCEPT_GAME_PATH=""
INTERCEPT_GAME_DIR=""
INTERCEPT_GAME_ID=""
INTERCEPT_GAME_EXT=""
INTERCEPT_GAME_ALTERNATIVE_PATH=""
INTERCEPT_SAVE_STATE=false
DISC_LAUNCHER_ERROR_SCREENS_DIR="${PSC_DISC_LAUNCHER_ERROR_SCREENS_DIR:-/media/project_eris/etc/project_eris/SUP/launchers/pscstore/assets/pscdisclauncher-error-screens}"
DISC_LAUNCHER_MODULES_DIR="/media/project_eris/etc/project_eris/SUP/cdrom"
INTERCEPT_FILE_FORMATS=(    # alternative PCSX ReARMed game formats
  "m3u"
  "pbp"
  "img"
  "iso"
  "mdf"
  "toc"
  "cbn"
  "chd"
)
UI_MENU_PID=""
### INTERCEPT FUNCTIONS #######################################################
delayed_sdl_display_kill() {
  sleep 30
  killall sdl_display
}
show_disc_launcher_error_screen() {
  # Prefer a dedicated error image if present, fall back to ra_loading.png
  local ERR_IMG=""

  if [ -f "${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_error.png" ]; then
    ERR_IMG="${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_error.png"
  elif [ -f "${THEMES_PATH}/${SELECTED_THEME}/menu_files/ra_loading.png" ]; then
    ERR_IMG="${THEMES_PATH}/${SELECTED_THEME}/menu_files/ra_loading.png"
  elif [ -f "${THEMES_PATH}/stock/menu_files/ra_loading.png" ]; then
    ERR_IMG="${THEMES_PATH}/stock/menu_files/ra_loading.png"
  fi

  if [ -n "${ERR_IMG}" ]; then
    echo "[PROJECT ERIS](INTERCEPT)(INFO) disc_launcher: showing error screen ${ERR_IMG}"
    "${PROJECT_ERIS_PATH}/bin/sdl_display" "${ERR_IMG}" &

    # Auto-dismiss after ~30s
    delayed_sdl_display_kill &
  else
    echo "[PROJECT ERIS](INTERCEPT)(WARN) disc_launcher: no error image found to display"
  fi
}
show_disc_launcher_invalid_disc_screen() {
  # Dedicated invalid-disc image, then fall back to disc_launcher_error / ra_loading
  local ERR_IMG=""

  if [ -f "${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_invalid_disc.png" ]; then
    ERR_IMG="${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_invalid_disc.png"
  elif [ -f "${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_error.png" ]; then
    ERR_IMG="${DISC_LAUNCHER_ERROR_SCREENS_DIR}/ra_disc_launcher_error.png"
  elif [ -f "${THEMES_PATH}/${SELECTED_THEME}/menu_files/ra_loading.png" ]; then
    ERR_IMG="${THEMES_PATH}/${SELECTED_THEME}/menu_files/ra_loading.png"
  elif [ -f "${THEMES_PATH}/stock/menu_files/ra_loading.png" ]; then
    ERR_IMG="${THEMES_PATH}/stock/menu_files/ra_loading.png"
  fi

  if [ -n "${ERR_IMG}" ]; then
    echo "[PROJECT ERIS](INTERCEPT)(INFO) disc_launcher: showing invalid-disc screen ${ERR_IMG}"
    "${PROJECT_ERIS_PATH}/bin/sdl_display" "${ERR_IMG}" &

    # Auto-dismiss after ~30s
    delayed_sdl_display_kill &
  else
    echo "[PROJECT ERIS](INTERCEPT)(WARN) disc_launcher: no invalid-disc image found to display"
  fi
}

